#!/bin/bash
# GitHub Actions の CD ワークフローを実行する
#
# Usage:
#   dev/deploy frontend stg       # フロントエンドを stg にデプロイ
set -euo pipefail

if [ $# -lt 2 ]; then
  echo "Usage: dev/deploy <target> <environment>"
  echo ""
  echo "  target:      frontend"
  echo "  environment: dev | stg | prod"
  echo ""
  echo "Examples:"
  echo "  dev/deploy frontend stg"
  exit 1
fi

TARGET="$1"
ENV="$2"
BRANCH="$(git branch --show-current)"

# 環境のバリデーション
case "$ENV" in
  dev|stg|prod) ;;
  *) echo "Error: environment は dev, stg, prod のいずれかを指定してください"; exit 1 ;;
esac

# prod デプロイの確認
if [ "$ENV" = "prod" ]; then
  echo "!! 本番環境へのデプロイです !!"
  read -r -p "続行しますか？ (yes/no): " confirm
  if [ "$confirm" != "yes" ]; then
    echo "キャンセルしました"
    exit 0
  fi
fi

deploy_frontend() {
  echo "== frontend デプロイ (env: $ENV, branch: $BRANCH) =="
  gh workflow run cd-frontend.yml --ref "$BRANCH" -f environment="$ENV"
  echo "[frontend] ワークフローをトリガーしました"
}

case "$TARGET" in
  frontend) deploy_frontend ;;
  *) echo "Error: target は frontend を指定してください"; exit 1 ;;
esac

echo ""
echo "デプロイ状況の確認:"
echo "  gh run list --workflow=cd-frontend.yml --limit=1"
