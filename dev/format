#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/.."
ROOT_DIR="$(pwd)"

# Backend
if [ -d "backend" ]; then
  echo "== backend: format =="
  cd backend
  uv run ruff format .
  cd "$ROOT_DIR"
fi

# Frontend
if [ -d "frontend" ]; then
  echo "== frontend: format =="
  cd frontend
  npm run format 2>/dev/null || echo "[frontend] npm run format が未定義のためスキップ"
  cd "$ROOT_DIR"
fi
