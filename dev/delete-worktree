#!/bin/bash
set -euo pipefail

# 現在のディレクトリがワークツリーかどうかを判定
REPO_ROOT="$(git rev-parse --show-toplevel)"
MAIN_WORKTREE="$(git worktree list --porcelain | head -1 | sed 's/^worktree //')"

if [ "$REPO_ROOT" = "$MAIN_WORKTREE" ]; then
  echo "Error: メインのワークツリーでは実行できません。"
  echo "ワークツリー内で実行してください。"
  exit 1
fi

BRANCH_NAME="$(git rev-parse --abbrev-ref HEAD)"

echo "以下のワークツリーを削除します:"
echo "  パス:     $REPO_ROOT"
echo "  ブランチ: $BRANCH_NAME"
echo ""

# 未コミットの変更があれば警告
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Warning: 未コミットの変更があります。"
  git status --short
  echo ""
fi

# 未プッシュのコミットがあれば警告
UPSTREAM="origin/${BRANCH_NAME}"
if git rev-parse --verify --quiet "$UPSTREAM" >/dev/null 2>&1; then
  UNPUSHED=$(git log "${UPSTREAM}..HEAD" --oneline 2>/dev/null || true)
  if [ -n "$UNPUSHED" ]; then
    echo "Warning: 未プッシュのコミットがあります:"
    echo "$UNPUSHED"
    echo ""
  fi
fi

read -p "本当に削除しますか？ [y/N]: " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "キャンセルしました。"
  exit 0
fi

# ワークツリーのディレクトリから離脱してから削除
cd "$MAIN_WORKTREE"
git worktree remove "$REPO_ROOT" --force

echo ""
echo "ワークツリーを削除しました: $REPO_ROOT"

# ブランチも削除するか確認
read -p "ブランチ '${BRANCH_NAME}' も削除しますか？ [y/N]: " confirm_branch
if [[ "$confirm_branch" =~ ^[Yy]$ ]]; then
  if git branch -d "$BRANCH_NAME" 2>/dev/null; then
    echo "ブランチを削除しました: $BRANCH_NAME"
  else
    echo "Warning: ブランチにマージされていない変更があります。"
    read -p "強制削除しますか？ [y/N]: " force_confirm
    if [[ "$force_confirm" =~ ^[Yy]$ ]]; then
      git branch -D "$BRANCH_NAME"
      echo "ブランチを強制削除しました: $BRANCH_NAME"
    else
      echo "ブランチの削除をスキップしました。"
    fi
  fi
fi
