{
  "name": "research-viewer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22",
    "bun": ">=1.1"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "check:mermaid": "node scripts/check-mermaid.mjs",
    "check:markdown": "markdownlint-cli2 --config ../.markdownlint-cli2.jsonc \"../research/**/*.md\"",
    "check:docs": "bun run check:markdown && bun run check:mermaid"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.2.0",
    "@aws-amplify/ui-react": "^6.8.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.3",
    "@fontsource-variable/noto-sans-jp": "^5.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "aws-amplify": "^6.14.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.5.0",
    "katex": "^0.16.21",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.23.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
